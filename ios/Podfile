# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  # Allow skipping problematic native plugins (like `mobile_scanner`) when
  # running simulator-only builds that use the Dart stub. Set
  # `USE_STUB_SCANNER=true` in the environment before running `pod install`
  # to remove `mobile_scanner` from the generated plugin list temporarily.
  if ENV['USE_STUB_SCANNER'] == 'true'
    generated = File.join(File.dirname(__FILE__), '.flutter-plugins-dependencies')
    if File.exist?(generated)
      require 'json'
      begin
        json = JSON.parse(File.read(generated))
        if json.key?('plugins') && json['plugins'].key?('ios')
          json['plugins']['ios'].reject! { |p| p['name'] == 'mobile_scanner' }
        end
        File.write(generated, JSON.pretty_generate(json))
      rescue => e
        puts "Warning: failed to modify #{generated}: #{e}"
      end
    end
  end

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

target 'OneSignalNotificationServiceExtension' do
  use_frameworks!
  pod 'OneSignalXCFramework', '>= 5.0.0', '< 6.0'
end

post_install do |installer|
  # If running with the stub flag, remove the mobile_scanner pod target
  # from the generated Pods project so it is not linked into simulator builds.
  if ENV['USE_STUB_SCANNER'] == 'true'
    installer.pods_project.targets.dup.each do |t|
      if t.name =~ /mobile_scanner/
        puts "Removing pod target #{t.name} because USE_STUB_SCANNER=true"
        installer.pods_project.targets.delete(t)
      end
    end
  end
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      # Keep i386 excluded by default (legacy simulators)
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
      # Speed up debug builds: compile each Swift file independently
      # (avoids whole-module recompilation on incremental changes)
      config.build_settings['SWIFT_COMPILATION_MODE'] = 'singlefile' if config.name == 'Debug'
      # Parallelize compilation across all available CPU cores
      config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-Onone' if config.name == 'Debug'
    end
  end
end
